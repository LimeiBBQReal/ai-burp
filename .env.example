# AIBURP 配置文件
# 复制此文件为 .env 并填入你的 API Key

# ============================================================
# LLM API Keys (Agent 模式必需)
# ============================================================

# Anthropic Claude (推荐) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI - https://platform.openai.com/
OPENAI_API_KEY=sk-xxx

# 指定模型 (可选)
AIBURP_LLM_MODEL=claude-3-5-sonnet-20241022

# ============================================================
# 外部 API Keys
# ============================================================

# Shodan - https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# Censys - https://platform.censys.io/account/api
# 新版只需要一个 API Key
CENSYS_API_KEY=your_censys_api_key_here
# 旧版兼容 (可选)
# CENSYS_API_ID=your_censys_api_id_here
# CENSYS_API_SECRET=your_censys_api_secret_here

# Fofa - https://fofa.info/
FOFA_EMAIL=your_fofa_email_here
FOFA_API_KEY=your_fofa_api_key_here

# Hunter - https://hunter.io/
HUNTER_API_KEY=your_hunter_api_key_here

# SecurityTrails - https://securitytrails.com/ (需要企业邮箱)
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# AlienVault OTX - https://otx.alienvault.com/api
OTX_API_KEY=your_otx_api_key_here

# VirusTotal - https://www.virustotal.com/
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ============================================================
# OOB (Out-of-Band) 服务
# ============================================================

# Burp Collaborator 或自建 OOB 服务器
OOB_SERVER=your_oob_server.com
OOB_API_KEY=your_oob_api_key_here

# Interactsh - https://github.com/projectdiscovery/interactsh
INTERACTSH_SERVER=oast.fun
INTERACTSH_TOKEN=

# ============================================================
# 代理设置
# ============================================================

# HTTP 代理 (用于流量分析)
HTTP_PROXY=
HTTPS_PROXY=

# SOCKS5 代理 (用于匿名)
SOCKS5_PROXY=

# ============================================================
# 其他设置
# ============================================================

# 请求延迟 (秒)
REQUEST_DELAY=0.5

# 最大并发数
MAX_CONCURRENCY=50

# User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

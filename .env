# AIBURP 配置文件
# 复制此文件为 .env 并填入你的 API Key

# ============================================================
# LLM API Keys (Agent 模式)
# 配置优先级: openai-primary → openai-backup → anthropic（自动回退）
# ============================================================

# 主 OpenAI 配置 (第一优先级)
OPENAI_API_BASE=https://newapi.huiqing.cyou/v1
OPENAI_API_KEY=sk-sAKAlCD3ymCbY1rhwNqeFORjEkD6Mr9c3XjO75zGtt8BsT8L
AIBURP_LLM_MODEL=deepseek-v4-pro

# 备份 OpenAI 配置 (第二优先级, 主 API 失败时自动回退)
# OPENAI_BACKUP_API_BASE=https://api.openai.com
# OPENAI_BACKUP_API_KEY=sk-your-backup-key-here
# OPENAI_BACKUP_MODEL=gpt-4  # 可选, 默认同 AIBURP_LLM_MODEL

# Anthropic Claude (第三优先级, 推荐)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Shodan - https://account.shodan.io/
SHODAN_API_KEY=PYjQu5PJVCrAYlu07OzrwIKSQj1k0eJu

# Censys - https://platform.censys.io/account/api
# 新版只需要一个 API Key
CENSYS_API_KEY=censys_FmSrVFTs_7wnSZc1tv9ttpd61bLpj9C7W

# Fofa - https://fofa.info/
FOFA_EMAIL=your_fofa_email_here
FOFA_API_KEY=your_fofa_api_key_here

# Hunter - https://hunter.io/
HUNTER_API_KEY=your_hunter_api_key_here

# SecurityTrails - https://securitytrails.com/ (需要企业邮箱)
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# AlienVault OTX - https://otx.alienvault.com/api
OTX_API_KEY=50071337516ea7265a87cd5c394c0568b10f7d514bf3e533d62b0af0ba783f7d

# VirusTotal - https://www.virustotal.com/
VIRUSTOTAL_API_KEY=b7c8c85adf22e881633deb2979b0ef4bcc4e7f84246b6e60017073e8ff84e814

# ============================================================
# OOB (Out-of-Band) 服务
# ============================================================

# Burp Collaborator 或自建 OOB 服务器
OOB_SERVER=your_oob_server.com
OOB_API_KEY=your_oob_api_key_here

# Interactsh - https://github.com/projectdiscovery/interactsh
INTERACTSH_SERVER=oast.fun
INTERACTSH_TOKEN=

# ============================================================
# 代理设置
# ============================================================

# HTTP 代理 (用于流量分析)
HTTP_PROXY=
HTTPS_PROXY=

# SOCKS5 代理 (用于匿名)
SOCKS5_PROXY=

# ============================================================
# 其他设置
# ============================================================

# 请求延迟 (秒)
REQUEST_DELAY=0.5

# 最大并发数
MAX_CONCURRENCY=50

# User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
